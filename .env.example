CHAT_API_KEY=your_chat_api_key
CHAT_BASE_URL=https://api.deepseek.com
CHAT_MODEL=deepseek-chat

# For OpenAI-compatible embedding endpoints.
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

DOCAGENT_SOURCE_DIR=data
DOCAGENT_PERSIST_DIR=.chroma
DOCAGENT_COLLECTION=docagent
DOCAGENT_TOP_K=4
DOCAGENT_MIN_RELEVANT_DOCS=1
DOCAGENT_MAX_RETRIES=2
DOCAGENT_CHUNK_SIZE=1200
DOCAGENT_CHUNK_OVERLAP=180
